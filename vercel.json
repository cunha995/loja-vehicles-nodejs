{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://je-automoveis.onrender.com/api/:path*"
    },
    {
      "source": "/contact",
      "destination": "https://je-automoveis.onrender.com/contact"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://je-automoveis.onrender.com/uploads/:path*"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/admin/:path*",
      "destination": "/admin.html"
    },
    {
      "source": "/master",
      "destination": "/master.html"
    },
    {
      "source": "/master/:path*",
      "destination": "/master.html"
    },
    {
      "source": "/loja/:path*",
      "destination": "/index.html"
    }
  ]
}
